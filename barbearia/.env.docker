# 1. Copie o .env configurado para Docker
cp .env.docker .env

# 2. Suba e construa os containers (primeira vez demora ~3 min)
docker compose up -d --build

# 3. Gere a chave da aplicação
docker compose exec php php artisan key:generate

# 4. Rode as migrations (cria clients, services, appointments...)
docker compose exec php php artisan migrate

# 5. Abra no navegador
# http://localhost:8080